# Copia este archivo como .env y rellena los valores reales
# NUNCA commitees .env al repo

# Pass Type ID registrado en Apple Developer Portal
# Ejemplo: pass.ai.integragroup.lealtad
PASS_TYPE_ID=pass.ai.integragroup.lealtad

# Team ID de tu cuenta Apple Developer (lo ves en la esquina inferior del portal)
# Ejemplo: AB1234WXYZ
TEAM_ID=XXXXXXXXXX

# Passphrase que usaste al exportar signerKey.pem con openssl
SIGNER_PASS=tu-passphrase-aqui
